        "options": {}
      },
      "id": "get-labeled-issues",
      "name": "GitHub: ai-implement 이슈 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const issues = $input.all().map(i => i.json);\n\nconst pending = issues.filter(issue => {\n  const labelNames = (issue.labels || []).map(l => l.name);\n  // ai-pr-created: 완료된 이슈 → 건너뜀\n  // ai-implementing: 현재 다른 실행이 처리 중 → 건너뜀 (중복 실행 방지)\n  // 두 라벨 모두 없음: 새 이슈 → 처리\n  return !labelNames.includes('ai-pr-created') && !labelNames.includes('ai-implementing');\n});\n\nif (pending.length === 0) {\n  return [{ json: { hasIssue: false } }];\n}\nconst issue = pending[0];\nreturn [{\n  json: {\n    hasIssue: true,\n    issueNumber: issue.number,\n    issueTitle: issue.title,\n    issueBody: issue.body || '(설명 없음)',\n    issueUrl: issue.html_url,\n    repoOwner: 'bae080311',\n    repoName: 'jump-section'\n  }\n}];"
      },
