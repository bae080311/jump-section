      "id": "get-index-ts",
      "name": "GitHub: index.ts 읽기",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const issueInfo = $('Issue 정보 추출').first().json;\nconst smFile = $('GitHub: ScrollManager.ts 읽기').first().json;\nconst indexFile = $('GitHub: index.ts 읽기').first().json;\n\nconst smContent = Buffer.from(smFile.content.replace(/\\n/g, ''), 'base64').toString('utf8');\nconst indexContent = Buffer.from(indexFile.content.replace(/\\n/g, ''), 'base64').toString('utf8');\n\n// 입력 크기 제한: 너무 크면 출력 토큰 부족으로 function call이 잘림\nconst smTruncated = smContent.length > 8000 ? smContent.slice(0, 8000) + '\\n// ... (truncated)' : smContent;\n\nconst userPrompt = `## Issue #${issueInfo.issueNumber}: ${issueInfo.issueTitle}\\n\\n${issueInfo.issueBody}\\n\\n---\\n\\n### packages/core/src/ScrollManager.ts\\n\\`\\`\\`typescript\\n${smTruncated}\\n\\`\\`\\`\\n\\n### packages/core/src/index.ts\\n\\`\\`\\`typescript\\n${indexContent}\\n\\`\\`\\`\\n\\nwrite_file 함수를 반드시 호출해 구현하세요. 테스트 파일도 포함하세요.`;\n\nconst geminiPayload = {\n  system_instruction: {\n    parts: [{ text: 'TypeScript 전문 개발자입니다. jump-section 라이브러리 신기능을 구현합니다.\\nPrettier(2sp, 세미콜론, 싱글쿼트, printWidth 100), strict 타입, Public API 하위 호환 유지.\\n반드시 write_file 함수만 사용해 결과를 제출하세요. 텍스트로 코드를 출력하지 마세요.' }]\n  },\n  contents: [{ role: 'user', parts: [{ text: userPrompt }] }],\n  tools: [{\n    functionDeclarations: [{\n      name: 'write_file',\n      description: '수정하거나 새로 생성할 파일의 전체 내용을 제출합니다.',\n      parameters: {\n        type: 'OBJECT',\n        properties: {\n          path: { type: 'STRING', description: '파일 경로' },\n          content: { type: 'STRING', description: '파일 전체 내용' },\n          description: { type: 'STRING', description: '변경 설명' }\n        },\n        required: ['path', 'content', 'description']\n      }\n    }]\n  }],\n  toolConfig: { functionCallingConfig: { mode: 'ANY', allowedFunctionNames: ['write_file'] } },\n  generationConfig: {\n    maxOutputTokens: 16384,\n    thinkingConfig: { thinkingBudget: 0 }\n  }\n};\n\nreturn [{\n  json: {\n    ...issueInfo,\n    scrollManagerSha: smFile.sha,\n    indexSha: indexFile.sha,\n    geminiPayload\n  }\n}];"
      },
      "id": "decode-files",
      "name": "파일 내용 디코딩",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
