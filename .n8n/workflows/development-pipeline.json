        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"ref\": \"refs/heads/{{ $('Tool Use 결과 파싱').first().json.branchName }}\",\n  \"sha\": \"{{ $json.object.sha }}\"\n}",
        "options": {}
      },
      "id": "create-branch",
      "name": "GitHub: 브랜치 생성",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2440,
        300
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const branchRes = $input.item.json;\nconst data = $('Tool Use 결과 파싱').first().json;\nconst mainSha = $('GitHub: main SHA 조회').first().json;\n\n// 브랜치 생성 성공이면 object.sha, 실패(이미 존재)면 main SHA 사용\nconst headCommitSha = (branchRes.object && branchRes.object.sha)\n  ? branchRes.object.sha\n  : mainSha.object.sha;\n\nconst tree = data.files.map(file => ({\n  path: (file.path || '').trim(),\n  mode: '100644',\n  type: 'blob',\n  content: (file.content || '').replace(/\\r/g, '\\n')\n}));\n\nconst commitMsg = `feat: implement issue #${data.issueNumber} - ${data.issueTitle.slice(0, 60)}`;\n\nreturn [{ json: {\n  repoOwner: data.repoOwner,\n  repoName: data.repoName,\n  branchName: data.branchName,\n  commitMessage: commitMsg,\n  tree,\n  headCommitSha,\n  issueNumber: data.issueNumber,\n  issueTitle: data.issueTitle,\n  issueUrl: data.issueUrl,\n  filesSummary: data.filesSummary\n} }];"
      },
