        "url": "=https://api.github.com/repos/{{ $('수정 결과 파싱').first().json.repoOwner }}/{{ $('수정 결과 파싱').first().json.repoName }}/issues/{{ $('수정 결과 파싱').first().json.prNumber }}/comments",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
